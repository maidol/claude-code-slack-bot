# Slack App Configuration (required)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Claude Code Configuration
# The bot uses the Claude CLI (run `claude login` first) — no API key needed by default.
# Set ANTHROPIC_API_KEY only if you explicitly want to bypass CLI auth.
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: route Claude CLI traffic through a proxy / gateway. Consumed by the
# Claude CLI itself (bot just forwards process.env to the child process).
# Only effective when authenticating with ANTHROPIC_API_KEY — OAuth auth ignores it.
# ANTHROPIC_BASE_URL=https://your-gateway.example.com

# Working Directory Configuration
# Base directory for relative paths.
#   Windows:  P:\your\base\directory
#   macOS:    /Users/username/Code/
#   Linux:    /home/username/code/
# When set, you can use `-cwd project-name` instead of full paths.
BASE_DIRECTORY=/Users/username/Code/

# Fallback working directory for DM threads when no `-cwd` has been set.
# Useful when you want the bot to default to a known repo for personal assistant use.
# DEFAULT_WORKING_DIRECTORY=/path/to/default/repo

# Default model for new conversations (alias: sonnet | opus | haiku, or full ID)
# Per-channel `-opus`/`-sonnet`/`-haiku` overrides this. `!o`/`!s`/`!h` prefix overrides per message.
# DEFAULT_MODEL=sonnet

# Comma-separated Slack user IDs allowed to use `-trust` mode (dangerously-skip-permissions).
# When unset, anyone can switch to trust mode. Set to lock down auto-approval to a few admins.
# ADMIN_USER_IDS=U0123ABC,U0456DEF

# Public holiday country (ISO 3166-1 alpha-2). Used by AssistantScheduler/ScheduleManager
# to skip non-working days. Default: KR.
# HOLIDAYS_COUNTRY=KR

# Optional: Use third-party providers (bypasses Claude CLI auth)
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1

# ─── Assistant Scheduler (optional) ──────────────────────────────────────────
# DM channel ID where the bot sends briefings, calendar reminders, and analysis reports.
# Find by opening the DM in Slack desktop and copying the URL fragment (D...).
# ASSISTANT_DM_CHANNEL=D0123456789
# Path to the assistant's config.json + prompts/ + reports/ directory.
# See docs/google-calendar-setup.md and assistant/* for the expected layout.
# ASSISTANT_CONFIG_DIR=/path/to/assistant/config

# ─── Local report HTTP server (renders -report markdown as HTML) ────────────
# Binds to 127.0.0.1, token-authenticated. Only starts when ASSISTANT_CONFIG_DIR is set.
# REPORTS_SERVER_ENABLED=1   # 0 to disable (default: enabled when ASSISTANT_CONFIG_DIR set)
# REPORTS_SERVER_PORT=8765   # falls back to +1..+5 if busy

# ─── System Memory Watchdog (Windows only, requires ASSISTANT_DM_CHANNEL) ───
# MEMORY_WATCHDOG_ENABLED=1                  # 0 to disable (default: enabled)
# MEMORY_WATCHDOG_THRESHOLD_PCT=90           # % of system commit limit to trigger (default: 90)
# MEMORY_WATCHDOG_INTERVAL_SEC=180           # check interval in seconds (default: 3 min)
# MEMORY_WATCHDOG_AUTO_KILL_SEC=600          # auto-kill delay (default: 10 minutes)
# MEMORY_WATCHDOG_PROCESS_THRESHOLD_MB=7168  # single-process commit MB to alert (default: 7 GB)

# ─── CLI streaming detail ───────────────────────────────────────────────────
# When enabled (default), the bot passes --include-partial-messages to `claude -p`,
# which makes tool-use status (e.g. "🔍 Using Grep") appear in Slack a few seconds earlier.
# Set to 0 if you observe Slack rate-limit warnings from chat.update during heavy parallel tool use.
# CLI_INCLUDE_PARTIAL=1   # 0 to disable (default: enabled)

# ─── Development ────────────────────────────────────────────────────────────
# DEBUG=true
