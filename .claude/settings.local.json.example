{
  "_comment": "Copy this file to settings.local.json and fill in your gateway credentials. The settings.local.json file is gitignored and must never be committed.",
  "_warning": "NOTE: env/apiKeyHelper here only take effect when the claude CLI's cwd is inside this repo. If a local interceptor like claude-mem/claude-code-router is installed, it may bypass these settings entirely (requests go through 127.0.0.1 sidecar instead). See README Troubleshooting -> 'ANTHROPIC_BASE_URL not taking effect'.",
  "env": {
    "ANTHROPIC_API_KEY": "sk-proxy-gateway-v1-REPLACE_ME",
    "ANTHROPIC_BASE_URL": "https://your-gateway.example.com"
  },
  "apiKeyHelper": "echo 'sk-proxy-gateway-v1-REPLACE_ME'",
  "permissions": {
    "allow": []
  }
}
